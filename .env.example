# ============================================================
# Environment Variables — AI Workout Trainer
# Copy this file to .env and fill in your keys
# ============================================================

# Supabase (existing project — same as Next.js app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Claude API (Phase 1)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI Whisper (Phase 2)
OPENAI_API_KEY=your-openai-api-key

# ElevenLabs (Phase 2)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-trainer-voice-id

# Pinecone (Phase 1)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=workout-trainer-memory

# Mubert (Phase 6)
MUBERT_API_KEY=your-mubert-api-key

# GCP (Phase 5)
GCP_PROJECT_ID=your-gcp-project-id
GCP_VIDEO_STITCH_URL=https://your-region-your-project.cloudfunctions.net/video-stitch
